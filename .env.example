# ============================================================
# AI Medical - Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env — only .env.example goes to GitHub.
# ============================================================

# --- Apollo ---
APOLLO_API_KEY=

# --- Google / Gmail ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_SENDER_ADDRESS=

# --- Instantly.ai ---
INSTANTLY_API_KEY=

# --- Supabase ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# --- Database (legacy, being replaced by Supabase) ---
DATABASE_URL=

# --- CRM ---
EXCEL_FILE_PATH=data/master_leads.xlsx
SQLITE_DB_PATH=data/crm_metadata.db

# --- General ---
APP_ENV=development

# ============================================================
